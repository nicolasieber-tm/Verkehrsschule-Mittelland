# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=false

# --- Database ---
DATABASE_URL=postgres://vsm:vsm@localhost:5432/vsm

# --- Session ---
SESSION_SECRET=replace-me-with-32-byte-random-hex-string-min

# --- CORS / Origin ---
# Komma-getrennte Liste erlaubter Origins für Public-POST und CORS
ALLOWED_ORIGINS=https://verkehrsschule-mittelland.ch,https://www.verkehrsschule-mittelland.ch

# --- E-Mail (Resend) ---
RESEND_API_KEY=
MAIL_FROM=anmeldung@verkehrsschule-mittelland.ch
MAIL_TO_SCHOOL=info@verkehrsschule-mittelland.ch

# URL des Admin-Backends, wird in den Schule-Benachrichtigungs-Mails als Link verwendet
ADMIN_BASE_URL=http://localhost:3000

# --- TOTP ---
TOTP_ISSUER=Verkehrsschule Mittelland

# --- DSG-Retention (Anonymizer Cron) ---
# Wie lange PII nach Kursende behalten (Tage)
ANONYMIZE_AFTER_DAYS=730
# Wie lange IP-Hashes behalten (Tage)
IP_HASH_RETENTION_DAYS=30
# Wie oft der Cron läuft (Minuten)
ANONYMIZE_INTERVAL_MINUTES=1440

# --- Admin-Bootstrap (nur für create-admin Script) ---
# wird zur Laufzeit nicht gelesen
