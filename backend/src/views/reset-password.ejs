<%- include('_header', { title: 'Neues Passwort setzen — VSM Admin' }) %>
<div class="card card-narrow">
  <h1>Neues Passwort setzen</h1>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <% if (info) { %><div class="info"><%= info %></div><% } %>
  <% if (!info) { %>
  <p class="muted" style="margin:0 0 16px">Wähle ein neues Passwort (mindestens 12 Zeichen). Nach dem Speichern wirst du zur Anmeldung weitergeleitet — dein 2FA-Code wird weiterhin abgefragt.</p>
  <form method="post" action="/admin/reset-password">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="token" value="<%= token %>">
    <label for="new">Neues Passwort</label>
    <input id="new" name="new" type="password" minlength="12" required autocomplete="new-password" autofocus>
    <label for="confirm">Passwort bestätigen</label>
    <input id="confirm" name="confirm" type="password" minlength="12" required autocomplete="new-password">
    <div style="margin-top:20px"><button type="submit" class="btn" style="width:100%">Passwort speichern</button></div>
  </form>
  <% } %>
  <p style="margin-top:20px;text-align:center"><a href="/admin/login" class="muted">← Zurück zur Anmeldung</a></p>
</div>
<%- include('_footer') %>
