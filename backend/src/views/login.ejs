<%- include('_header', { title: 'Anmeldung — VSM Admin' }) %>
<div class="card card-narrow">
  <h1>Anmeldung</h1>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <% if (info) { %><div class="info"><%= info %></div><% } %>
  <form method="post" action="/admin/login">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="email">Email</label>
    <input id="email" name="email" type="email" required autocomplete="username" autofocus value="<%= email || '' %>">
    <label for="password">Passwort</label>
    <input id="password" name="password" type="password" required autocomplete="current-password">
    <div style="margin-top:20px"><button type="submit" class="btn" style="width:100%">Anmelden</button></div>
  </form>
</div>
<%- include('_footer') %>
