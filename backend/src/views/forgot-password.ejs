<%- include('_header', { title: 'Passwort vergessen — VSM Admin' }) %>
<div class="card card-narrow">
  <h1>Passwort vergessen</h1>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <% if (info) { %><div class="info"><%= info %></div><% } %>
  <% if (!info) { %>
  <p class="muted" style="margin:0 0 16px">Gib deine E-Mail-Adresse ein. Falls ein Admin-Account mit dieser Adresse existiert, schicken wir dir einen Link zum Zurücksetzen.</p>
  <form method="post" action="/admin/forgot-password">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="email">Email</label>
    <input id="email" name="email" type="email" required autocomplete="username" autofocus value="<%= email || '' %>">
    <div style="margin-top:20px"><button type="submit" class="btn" style="width:100%">Link anfordern</button></div>
  </form>
  <% } %>
  <p style="margin-top:20px;text-align:center"><a href="/admin/login" class="muted">← Zurück zur Anmeldung</a></p>
</div>
<%- include('_footer') %>
