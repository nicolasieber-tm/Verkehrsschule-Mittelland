<%- include('../_header', { title: 'Gutscheine — VSM Admin' }) %>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
  <h1 style="margin:0">Gutschein-Bestellungen</h1>
  <div class="actions">
    <a class="btn btn-ghost" href="/admin/vouchers.csv<%= filterStatus ? '?status=' + encodeURIComponent(filterStatus) : '' %>">CSV-Export</a>
  </div>
</div>
<% if (success) { %><div class="success"><%= success %></div><% } %>
<% if (error) { %><div class="error"><%= error %></div><% } %>

<div class="card" style="padding:12px 16px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
  <span class="muted" style="font-size:13px">Filter:</span>
  <a href="/admin/vouchers" class="btn <%= !filterStatus ? '' : 'btn-ghost' %>" style="padding:6px 14px;font-size:13px">Alle</a>
  <a href="/admin/vouchers?status=new" class="btn <%= filterStatus === 'new' ? '' : 'btn-ghost' %>" style="padding:6px 14px;font-size:13px">Neu</a>
  <a href="/admin/vouchers?status=contacted" class="btn <%= filterStatus === 'contacted' ? '' : 'btn-ghost' %>" style="padding:6px 14px;font-size:13px">Kontaktiert</a>
  <a href="/admin/vouchers?status=shipped" class="btn <%= filterStatus === 'shipped' ? '' : 'btn-ghost' %>" style="padding:6px 14px;font-size:13px">Versendet</a>
  <a href="/admin/vouchers?status=closed" class="btn <%= filterStatus === 'closed' ? '' : 'btn-ghost' %>" style="padding:6px 14px;font-size:13px">Abgeschlossen</a>
  <a href="/admin/vouchers?status=cancelled" class="btn <%= filterStatus === 'cancelled' ? '' : 'btn-ghost' %>" style="padding:6px 14px;font-size:13px">Storniert</a>
</div>

<div class="card" style="padding:0;overflow-x:auto">
<table>
  <thead>
    <tr>
      <th>Empfänger</th>
      <th>Betrag</th>
      <th>Besteller</th>
      <th>E-Mail</th>
      <th>Eingegangen</th>
      <th>Bezahlt</th>
      <th>Status</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% if (orders.length === 0) { %>
      <tr><td colspan="8" style="text-align:center;padding:32px;color:#6a7180">Keine Bestellungen.</td></tr>
    <% } %>
    <% orders.forEach(function(o) { %>
      <tr>
        <td><strong><%= o.fuer %></strong><br><span class="muted">von <%= o.von %></span></td>
        <td><strong>CHF <%= o.betrag_chf %></strong></td>
        <td><%= o.rvname %> <%= o.rnname %></td>
        <td><%= o.email %><% if (o.telefon) { %><br><span class="muted"><%= o.telefon %></span><% } %></td>
        <td><%= formatZurich(o.created_at) %></td>
        <td>
          <% if (o.paid) { %><span class="badge badge-green">bezahlt</span>
          <% } else { %><span class="badge badge-gray">offen</span><% } %>
        </td>
        <td>
          <% if (o.status === 'new') { %><span class="badge badge-green">neu</span>
          <% } else if (o.status === 'contacted') { %><span class="badge badge-gray">kontaktiert</span>
          <% } else if (o.status === 'shipped') { %><span class="badge badge-green">versendet</span>
          <% } else if (o.status === 'closed') { %><span class="badge badge-gray">abgeschlossen</span>
          <% } else { %><span class="badge badge-red">storniert</span><% } %>
        </td>
        <td><a href="/admin/vouchers/<%= o.id %>">Öffnen</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
</div>
<%- include('../_footer') %>
