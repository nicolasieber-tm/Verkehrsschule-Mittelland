<%- include('_header', { title: 'Dashboard — VSM Admin' }) %>
<h1>Dashboard</h1>

<div class="row">
  <div class="card">
    <h2 style="margin-top:0">Kommende Kurse</h2>
    <% if (upcoming.length === 0) { %>
      <p class="muted">Noch keine kommenden Kurse. <a href="/admin/courses/new">Jetzt anlegen</a></p>
    <% } else { %>
      <table>
        <thead><tr><th>Kursnr.</th><th>Start</th><th>Plätze</th></tr></thead>
        <tbody>
          <% upcoming.forEach(function(c) { %>
            <tr>
              <td><a href="/admin/courses/<%= c.id %>"><%= c.course_no %></a></td>
              <td><%= formatZurich(c.starts_at) %></td>
              <td><%= c.booked_seats %> / <%= c.max_seats %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="card">
    <h2 style="margin-top:0">Neueste Anmeldungen</h2>
    <% if (recentRegs.length === 0) { %>
      <p class="muted">Noch keine Anmeldungen.</p>
    <% } else { %>
      <table>
        <thead><tr><th>Name</th><th>Kurs</th><th>Eingegangen</th></tr></thead>
        <tbody>
          <% recentRegs.forEach(function(r) { %>
            <tr>
              <td><%= r.vname %> <%= r.nname %></td>
              <td><%= r.course_no %></td>
              <td><%= formatZurich(r.created_at) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<% if (typeof recentRequests !== 'undefined') { %>
<div class="card">
  <h2 style="margin-top:0">Neueste Anfragen</h2>
  <% if (recentRequests.length === 0) { %>
    <p class="muted">Noch keine Anfragen.</p>
  <% } else { %>
    <table>
      <thead><tr><th>Name</th><th>Paket</th><th>Status</th><th>Eingegangen</th></tr></thead>
      <tbody>
        <% recentRequests.forEach(function(r) { %>
          <tr>
            <td><a href="/admin/package-requests/<%= r.id %>"><%= r.vname %> <%= r.nname %></a></td>
            <td><%= typeLabel(r.type) %><% if (r.with_vku) { %> + VKU<% } %></td>
            <td><span class="badge <%= r.status === 'new' ? 'badge-green' : (r.status === 'cancelled' ? 'badge-red' : 'badge-gray') %>"><%= r.status %></span></td>
            <td><%= formatZurich(r.created_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p style="margin-top:12px"><a href="/admin/package-requests">Alle Anfragen →</a></p>
  <% } %>
</div>
<% } %>

<% if (typeof recentVouchers !== 'undefined') { %>
<div class="card">
  <h2 style="margin-top:0">Neueste Gutschein-Bestellungen</h2>
  <% if (recentVouchers.length === 0) { %>
    <p class="muted">Noch keine Gutschein-Bestellungen.</p>
  <% } else { %>
    <table>
      <thead><tr><th>Empfänger</th><th>Betrag</th><th>Besteller</th><th>Status</th><th>Eingegangen</th></tr></thead>
      <tbody>
        <% recentVouchers.forEach(function(v) { %>
          <tr>
            <td><a href="/admin/vouchers/<%= v.id %>"><%= v.fuer %></a></td>
            <td>CHF <%= v.betrag_chf %></td>
            <td><%= v.rvname %> <%= v.rnname %></td>
            <td>
              <% if (v.status === 'new') { %><span class="badge badge-green">neu</span>
              <% } else if (v.status === 'shipped') { %><span class="badge badge-green">versendet</span>
              <% } else if (v.status === 'cancelled') { %><span class="badge badge-red">storniert</span>
              <% } else { %><span class="badge badge-gray"><%= v.status %></span><% } %>
              <% if (v.paid) { %><span class="badge badge-green" style="margin-left:4px">bezahlt</span><% } %>
            </td>
            <td><%= formatZurich(v.created_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p style="margin-top:12px"><a href="/admin/vouchers">Alle Gutscheine →</a></p>
  <% } %>
</div>
<% } %>
<%- include('_footer') %>
